<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="RyzenTunerNext.App.Views.ProfilerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:RyzenTunerNext.App.ViewModels"
    NavigationCacheMode="Required">

    <Page.DataContext>
        <vm:ProfilerViewModel />
    </Page.DataContext>

    <Grid Padding="32,24,32,32" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="能效分析" Style="{StaticResource TitleTextBlockStyle}" />

        <!-- 操作区 -->
        <StackPanel Grid.Row="1" Spacing="12">
            <TextBlock Text="基准测试" Style="{StaticResource SubtitleTextBlockStyle}" />
            <TextBlock
                Text="自写 C# 基准测试，多线程素数计数。依次测试不同功耗档位，生成能效对比报告。"
                TextWrapping="Wrap"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button
                    Content="多核测试"
                    Command="{Binding RunMultiCoreTestCommand}"
                    IsEnabled="{Binding IsRunning, Converter={StaticResource BoolInverse}}" />
                <Button
                    Content="单核测试"
                    Command="{Binding RunSingleCoreTestCommand}"
                    IsEnabled="{Binding IsRunning, Converter={StaticResource BoolInverse}}" />
                <Button Content="加载历史" Command="{Binding LoadHistoryCommand}" />
                <Button Content="清空历史" Command="{Binding ClearHistoryCommand}" />
            </StackPanel>
        </StackPanel>

        <!-- 进度 -->
        <StackPanel Grid.Row="2" Spacing="8" Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="{Binding StatusText}" />
            <ProgressBar Value="{Binding Progress}" Maximum="100" />
        </StackPanel>
        <TextBlock Grid.Row="2" Text="{Binding StatusText}"
                   Visibility="{Binding IsRunning, Converter={StaticResource BoolInverseVisibility}}" />

        <!-- 结果表格 -->
        <ListView
            Grid.Row="3"
            ItemsSource="{Binding Results}"
            IsItemClickEnabled="False"
            SelectionMode="None">
            <ListView.Header>
                <Grid Padding="0,8" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="设定功耗" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="跑分成绩" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="2" Text="CPU 频率" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="3" Text="实际功耗" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="4" Text="CPU 温度" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="5" Text="能效比" FontWeight="SemiBold" />
                </Grid>
            </ListView.Header>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:ProfilerResult"
                              xmlns:models="using:RyzenTunerNext.Core.Models">
                    <Grid Padding="0,4" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{x:Bind FastLimit}" />
                        <TextBlock Grid.Column="1" Text="{x:Bind Score}" />
                        <TextBlock Grid.Column="2" Text="{x:Bind AvgFrequency, Mode=OneWay}" />
                        <TextBlock Grid.Column="3" Text="{x:Bind AvgPower, Mode=OneWay}" />
                        <TextBlock Grid.Column="4" Text="{x:Bind MaxTemp, Mode=OneWay}" />
                        <TextBlock Grid.Column="5" Text="{x:Bind Efficiency, Mode=OneWay}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
