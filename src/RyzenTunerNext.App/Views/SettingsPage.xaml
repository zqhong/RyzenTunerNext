<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="RyzenTunerNext.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:RyzenTunerNext.App.ViewModels"
    NavigationCacheMode="Required">

    <Page.DataContext>
        <vm:SettingsViewModel />
    </Page.DataContext>

    <ScrollViewer Padding="32,24,32,32">
        <StackPanel Spacing="24" MaxWidth="800">

            <TextBlock Text="设置" Style="{StaticResource TitleTextBlockStyle}" />

            <!-- ==================== Service 管理 ==================== -->
            <TextBlock Text="Service 管理" Style="{StaticResource SubtitleTextBlockStyle}" />
            <StackPanel Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon
                        FontFamily="Segoe Fluent Icons"
                        FontSize="16"
                        Glyph="{Binding ServiceRunning, Converter={StaticResource BoolToGlyphConverter}}" />
                    <TextBlock Text="{Binding ServiceStatusText, Mode=OneWay}" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="安装" Command="{Binding InstallServiceCommand}"
                            Visibility="{Binding ServiceInstalled, Converter={StaticResource BoolInverseVisibility}}" />
                    <Button Content="卸载" Command="{Binding UninstallServiceCommand}"
                            Visibility="{Binding ServiceInstalled, Converter={StaticResource BoolToVisibility}}" />
                    <Button Content="启动" Command="{Binding StartServiceCommand}"
                            Visibility="{Binding ServiceRunning, Converter={StaticResource BoolInverseVisibility}}"
                            Style="{StaticResource AccentButtonStyle}" />
                    <Button Content="停止" Command="{Binding StopServiceCommand}"
                            Visibility="{Binding ServiceRunning, Converter={StaticResource BoolToVisibility}}" />
                    <Button Content="刷新状态" Command="{Binding RefreshServiceStatusCommand}" />
                </StackPanel>
            </StackPanel>

            <!-- ==================== 性能模式参数 ==================== -->
            <TextBlock Text="性能模式" Style="{StaticResource SubtitleTextBlockStyle}" />
            <StackPanel Spacing="12">
                <NumberBox
                    Header="Fast Limit (mW)"
                    Value="{Binding FastLimitPerformance, Mode=TwoWay}"
                    Minimum="5000"
                    Maximum="100000"
                    SpinButtonPlacementMode="Inline">
                    <ToolTipService.ToolTip>
                        <ToolTip Content="峰值功耗上限 (PPT FAST)。必须大于等于 Slow Limit。部分机型 BIOS 锁定了最大值。" />
                    </ToolTipService.ToolTip>
                </NumberBox>
                <NumberBox
                    Header="Slow Limit (mW)"
                    Value="{Binding SlowLimitPerformance, Mode=TwoWay}"
                    Minimum="5000"
                    Maximum="100000"
                    SpinButtonPlacementMode="Inline">
                    <ToolTipService.ToolTip>
                        <ToolTip Content="持续功耗上限 (PPT SLOW)。STAPM Limit 会自动等于此值。" />
                    </ToolTipService.ToolTip>
                </NumberBox>
            </StackPanel>

            <!-- ==================== 省电模式参数 ==================== -->
            <TextBlock Text="省电模式" Style="{StaticResource SubtitleTextBlockStyle}" />
            <StackPanel Spacing="12">
                <NumberBox
                    Header="Fast Limit (mW)"
                    Value="{Binding FastLimitPowersaving, Mode=TwoWay}"
                    Minimum="5000"
                    Maximum="100000"
                    SpinButtonPlacementMode="Inline" />
                <NumberBox
                    Header="Slow Limit (mW)"
                    Value="{Binding SlowLimitPowersaving, Mode=TwoWay}"
                    Minimum="5000"
                    Maximum="100000"
                    SpinButtonPlacementMode="Inline" />
            </StackPanel>

            <!-- ==================== 全局配置 ==================== -->
            <TextBlock Text="全局配置" Style="{StaticResource SubtitleTextBlockStyle}" />
            <StackPanel Spacing="12">
                <NumberBox
                    Header="Tctl 温度 (℃)"
                    Value="{Binding TctlTemp, Mode=TwoWay}"
                    Minimum="80"
                    Maximum="95"
                    SpinButtonPlacementMode="Inline">
                    <ToolTipService.ToolTip>
                        <ToolTip Content="CPU 温度目标。建议比 Prochot 温度低 5-10℃。过低会触发降频。" />
                    </ToolTipService.ToolTip>
                </NumberBox>
                <NumberBox
                    Header="更新频率 (ms)"
                    Value="{Binding ApplyInterval, Mode=TwoWay}"
                    Minimum="1000"
                    Maximum="30000"
                    SpinButtonPlacementMode="Inline" />
                <NumberBox
                    Header="日志保留天数"
                    Value="{Binding LogRetentionDays, Mode=TwoWay}"
                    Minimum="1"
                    Maximum="365"
                    SpinButtonPlacementMode="Inline" />
            </StackPanel>

            <!-- ==================== 快捷键 ==================== -->
            <TextBlock Text="快捷键" Style="{StaticResource SubtitleTextBlockStyle}" />
            <StackPanel Spacing="12">
                <StackPanel Spacing="4">
                    <TextBlock Text="切换模式" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBox
                        Header="快捷键组合"
                        PlaceholderText="点击后按下快捷键组合..."
                        Text="{Binding HotkeyToggleMode, Mode=TwoWay}"
                        IsReadOnly="True"
                        GotFocus="HotkeyBox_GotFocus"
                        LostFocus="HotkeyBox_LostFocus"
                        KeyDown="HotkeyBox_KeyDown"
                        Tag="ToggleMode" />
                </StackPanel>
                <StackPanel Spacing="4">
                    <TextBlock Text="立即应用" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBox
                        Header="快捷键组合"
                        PlaceholderText="点击后按下快捷键组合..."
                        Text="{Binding HotkeyApplyNow, Mode=TwoWay}"
                        IsReadOnly="True"
                        GotFocus="HotkeyBox_GotFocus"
                        LostFocus="HotkeyBox_LostFocus"
                        KeyDown="HotkeyBox_KeyDown"
                        Tag="ApplyNow" />
                </StackPanel>
                <StackPanel Spacing="4">
                    <TextBlock Text="显示/隐藏窗口" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBox
                        Header="快捷键组合"
                        PlaceholderText="点击后按下快捷键组合..."
                        Text="{Binding HotkeyShowWindow, Mode=TwoWay}"
                        IsReadOnly="True"
                        GotFocus="HotkeyBox_GotFocus"
                        LostFocus="HotkeyBox_LostFocus"
                        KeyDown="HotkeyBox_KeyDown"
                        Tag="ShowWindow" />
                </StackPanel>
            </StackPanel>

            <!-- ==================== 外观 ==================== -->
            <TextBlock Text="外观" Style="{StaticResource SubtitleTextBlockStyle}" />
            <StackPanel Spacing="12">
                <ComboBox
                    Header="主题"
                    ItemsSource="{Binding ThemeOptions}"
                    SelectedIndex="{Binding SelectedThemeIndex, Mode=TwoWay}"
                    Width="200"
                    HorizontalAlignment="Left" />
                <ComboBox
                    Header="语言"
                    ItemsSource="{Binding LanguageOptions}"
                    SelectedIndex="{Binding SelectedLanguageIndex, Mode=TwoWay}"
                    Width="200"
                    HorizontalAlignment="Left" />
            </StackPanel>

            <!-- ==================== 保存按钮 ==================== -->
            <Button
                Content="保存设置"
                Style="{StaticResource AccentButtonStyle}"
                Command="{Binding SaveCommand}" />

        </StackPanel>
    </ScrollViewer>
</Page>
