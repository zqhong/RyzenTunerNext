<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="RyzenTunerNext.App.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:RyzenTunerNext.App.Controls"
    xmlns:vm="using:RyzenTunerNext.App.ViewModels"
    NavigationCacheMode="Required">

    <Page.DataContext>
        <vm:HomeViewModel />
    </Page.DataContext>

    <ScrollViewer Padding="32,24,32,32">
        <StackPanel Spacing="24" MaxWidth="800">

            <!-- 连接状态 -->
            <InfoBar
                x:Name="ConnectionBar"
                IsOpen="True"
                Severity="Warning"
                Title="未连接到 Service"
                Message="请确认 RyzenTunerNext Service 已安装并启动。"
                Visibility="{Binding IsConnected, Converter={StaticResource BoolInverseVisibility}}" />

            <!-- Cap 警告 -->
            <InfoBar
                x:Name="CapWarningBar"
                IsOpen="{Binding CapWarning, Converter={StaticResource StringToBool}}"
                Severity="Warning"
                Title="参数被 BIOS 锁定"
                Message="{Binding CapWarning}"
                Visibility="{Binding CapWarning, Converter={StaticResource StringToVisibility}}" />

            <!-- 标题 -->
            <TextBlock Text="首页" Style="{StaticResource TitleTextBlockStyle}" />

            <!-- 能耗模式切换 -->
            <StackPanel Spacing="8">
                <TextBlock Text="能耗模式" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <ComboBox
                    x:Name="ModeComboBox"
                    Width="200"
                    HorizontalAlignment="Left"
                    SelectedIndex="0"
                    SelectionChanged="ModeComboBox_SelectionChanged">
                    <ToolTipService.ToolTip>
                        <ToolTip Content="自动：根据用户活动和 CPU 负载自动切换省电/性能模式。省电：固定使用省电模式参数。性能：固定使用性能模式参数。" />
                    </ToolTipService.ToolTip>
                    <ComboBoxItem Content="自动" />
                    <ComboBoxItem Content="省电模式" />
                    <ComboBoxItem Content="性能模式" />
                </ComboBox>
            </StackPanel>

            <!-- 当前状态 -->
            <TextBlock Text="当前状态" Style="{StaticResource SubtitleTextBlockStyle}" />
            <StackPanel Orientation="Horizontal" Spacing="16">
                <controls:StatCard
                    Label="CPU 频率"
                    Value="{Binding CpuFrequency, StringFormat=F0}"
                    Unit="MHz"
                    Icon="&#xE950;" />
                <controls:StatCard
                    Label="整机功耗"
                    Value="{Binding SocketPower, StringFormat=F1}"
                    Unit="W"
                    Icon="&#xE945;" />
                <controls:StatCard
                    Label="CPU 温度"
                    Value="{Binding CpuTemp, StringFormat=F0}"
                    Unit="℃"
                    Icon="&#xEB91;" />
            </StackPanel>

            <!-- 生效参数 -->
            <TextBlock Text="生效参数" Style="{StaticResource SubtitleTextBlockStyle}" />
            <StackPanel Orientation="Horizontal" Spacing="16">
                <controls:StatCard
                    Label="Fast Limit"
                    Value="{Binding FastLimitActual, StringFormat=F1}"
                    Unit="W"
                    Icon="&#xE945;" />
                <controls:StatCard
                    Label="Slow Limit"
                    Value="{Binding SlowLimitActual, StringFormat=F1}"
                    Unit="W"
                    Icon="&#xE945;" />
                <controls:StatCard
                    Label="Tctl 温度"
                    Value="{Binding TctlTempActual, StringFormat=F0}"
                    Unit="℃"
                    Icon="&#xEB91;" />
            </StackPanel>

            <!-- 手动操作 -->
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Content="立即应用" Click="ApplyNow_Click" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
