<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="RyzenTunerNext.App.Views.LogPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:RyzenTunerNext.App.ViewModels"
    NavigationCacheMode="Required">

    <Page.DataContext>
        <vm:LogViewModel />
    </Page.DataContext>

    <Grid Padding="32,24,32,32" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="运行日志" Style="{StaticResource TitleTextBlockStyle}" />

        <!-- 筛选栏 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12">
            <AutoSuggestBox
                PlaceholderText="搜索日志..."
                QueryIcon="Find"
                Width="300"
                TextChanged="SearchBox_TextChanged" />
            <ComboBox
                x:Name="LevelFilter"
                Header="日志级别"
                ItemsSource="{Binding Levels}"
                SelectedIndex="0"
                SelectionChanged="LevelFilter_SelectionChanged" />
            <Button Content="刷新" Command="{Binding LoadLogsCommand}" />
            <Button Content="清理旧日志" Command="{Binding CleanupCommand}" />
        </StackPanel>

        <!-- 日志列表 -->
        <ListView
            Grid.Row="2"
            ItemsSource="{Binding Logs}"
            IsItemClickEnabled="False"
            SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:LogEntry"
                              xmlns:models="using:RyzenTunerNext.Core.Models">
                    <Grid Padding="0,8" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- 时间 -->
                        <TextBlock Grid.Column="0"
                                   Text="{x:Bind Timestamp}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   MinWidth="160" />

                        <!-- 级别图标 -->
                        <FontIcon Grid.Column="1"
                                  FontFamily="Segoe Fluent Icons"
                                  FontSize="14"
                                  VerticalAlignment="Center"
                                  Glyph="{x:Bind Level, Converter={StaticResource LogLevelToGlyphConverter}}" />

                        <!-- 来源 -->
                        <TextBlock Grid.Column="2"
                                   Text="{x:Bind Source}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   FontWeight="SemiBold"
                                   MinWidth="60" />

                        <!-- 消息 -->
                        <TextBlock Grid.Column="3"
                                   Text="{x:Bind Message}"
                                   TextWrapping="Wrap" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
