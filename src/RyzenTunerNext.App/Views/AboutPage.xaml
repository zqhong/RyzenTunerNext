<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="RyzenTunerNext.App.Views.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:RyzenTunerNext.App.ViewModels"
    NavigationCacheMode="Required">

    <Page.DataContext>
        <vm:AboutViewModel />
    </Page.DataContext>

    <ScrollViewer Padding="32,24,32,32">
        <StackPanel Spacing="24" MaxWidth="600">

            <TextBlock Text="关于" Style="{StaticResource TitleTextBlockStyle}" />

            <!-- 应用信息 -->
            <StackPanel Spacing="12">
                <TextBlock Text="RyzenTunerNext" FontSize="24" FontWeight="SemiBold" />
                <TextBlock Text="AMD Ryzen 移动平台功耗调节工具"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- 版本信息 -->
            <TextBlock Text="版本信息" Style="{StaticResource SubtitleTextBlockStyle}" />
            <StackPanel Spacing="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="应用版本" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="{Binding Version}" />
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="RyzenAdj 引擎" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="{Binding EngineVersion}" />
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="框架" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="{Binding Framework}" />
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="CPU Family" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="{Binding CpuFamily}" />
                </Grid>
            </StackPanel>

            <!-- 运行状态 -->
            <TextBlock Text="运行状态" Style="{StaticResource SubtitleTextBlockStyle}" />
            <StackPanel Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <!-- E73E=CheckMark, E711=Cancel -->
                    <FontIcon
                        FontFamily="Segoe Fluent Icons"
                        FontSize="16"
                        Foreground="{ThemeResource SystemAccentColor}"
                        Glyph="{Binding RyzenAdjInitialized, Converter={StaticResource BoolToGlyphConverter}}" />
                    <TextBlock Text="RyzenAdj 引擎" />
                </StackPanel>
            </StackPanel>

            <!-- 说明 -->
            <TextBlock Text="技术说明" Style="{StaticResource SubtitleTextBlockStyle}" />
            <TextBlock TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                RyzenTunerNext 是 RyzenAdj 的 Windows GUI 匍端，采用 Windows Service + WinUI 3 双进程架构。
                Service 以 SYSTEM 权限运行，确保 WinRing0 驱动加载稳定；GUI 以普通用户权限运行，提供可视化操作界面。
                两者通过 Named Pipe 实时通信，SQLite (WAL) 共享配置和状态。
            </TextBlock>

            <TextBlock TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                注意：RyzenAdj 的设置重启后不保留，电源模式切换也会重置参数。Service 会持续循环写入以维持设置。
            </TextBlock>

        </StackPanel>
    </ScrollViewer>
</Page>
